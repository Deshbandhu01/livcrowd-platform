rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: locations
    // Fields: name (string), description (string), capacity (int), currentCrowd (int), baseWaitTimePerPerson (float), trend (string), lastUpdated (timestamp), trafficInfo (string), latitude (float), longitude (float), address (string), bestTimeToVisit (string)
    //
    // Collection: locations/{locationId}/events
    // Fields: locationId (string), timestamp (timestamp), crowdCount (int)
    //
    // Collection: users
    // Fields: email (string), role (string: 'admin' | 'user')
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         ((request.auth.token.email == "dbadhauliya@gmail.com" || request.auth.token.email == "dbadhauliya01@gmail.com") && 
          request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(data, allowedFields) {
      return data.keys().hasOnly(allowedFields);
    }

    function isValidLocation(data) {
      let allowedFields = ['name', 'description', 'capacity', 'currentCrowd', 'baseWaitTimePerPerson', 'trend', 'lastUpdated', 'trafficInfo', 'latitude', 'longitude', 'address', 'bestTimeToVisit'];
      return hasOnlyAllowedFields(data, allowedFields) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.capacity is int && data.capacity > 0 &&
             data.currentCrowd is int && data.currentCrowd >= 0 &&
             (data.trend in ['INCREASING', 'DECREASING', 'STABLE']) &&
             (!('trafficInfo' in data) || (data.trafficInfo is string && data.trafficInfo.size() < 1000)) &&
             (!('latitude' in data) || (data.latitude is number)) &&
             (!('longitude' in data) || (data.longitude is number)) &&
             (!('address' in data) || (data.address is string && data.address.size() < 500)) &&
             (!('bestTimeToVisit' in data) || (data.bestTimeToVisit is string && data.bestTimeToVisit.size() < 200));
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(data, ['uid', 'email', 'role', 'displayName', 'bio', 'avatarUrl', 'phoneNumber']) &&
             data.uid == request.auth.uid &&
             data.email is string && 
             data.role in ['admin', 'user'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() < 500)) &&
             (!('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() < 500)) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() < 20));
    }

    function isValidSearch(data) {
      return hasOnlyAllowedFields(data, ['query', 'userId', 'timestamp', 'status']) &&
             data.query is string && data.query.size() > 0 && data.query.size() < 500 &&
             data.userId == request.auth.uid &&
             data.timestamp is timestamp &&
             data.status in ['found', 'not_found'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role);
    }

    match /searchHistory/{historyId} {
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidSearch(request.resource.data);
    }

    match /locations/{locationId} {
      allow read: if true; // Publicly readable for dashboard
      allow create, update, delete: if isAdmin();
      
      match /events/{eventId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }
    }
  }
}
